    // Insertion Sort
    insertionSort(a, n);
    printf("\nAfter Insertion Sort: ");
    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    // Quick Sort
    quickSort(a, 0, n - 1);
    printf("\nAfter Quick Sort: ");
    for(i = 0; i < n; i++)
