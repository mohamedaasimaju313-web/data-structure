6.Implement a hash table.

#include <stdio.h>

#define SIZE 10

int hashTable[SIZE];

// Insert into hash table
void insert(int key) {
    int index = key % SIZE;

    while(hashTable[index] != -1) {
        index = (index + 1) % SIZE;   // linear probing
    }
    hashTable[index] = key;
}

// Search element
int search(int key) {
    int index = key % SIZE;

    while(hashTable[index] != -1) {
        if(hashTable[index] == key)
            return index;
        index = (index + 1) % SIZE;
    }
    return -1;
}

int main() {
    int i, n, key;

    // Initialize table with -1
    for(i = 0; i < SIZE; i++)
        hashTable[i] = -1;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &key);
        insert(key);
    }

    // Display hash table
    printf("\nHash Table:\n");
    for(i = 0; i < SIZE; i++)
        printf("%d ", hashTable[i]);

    printf("\n\nEnter element to search: ");
    scanf("%d", &key);

    int pos = search(key);
    if(pos != -1)
        printf("Element found at index %d", pos);
    else
        printf("Element not found");

    return 0;
}

