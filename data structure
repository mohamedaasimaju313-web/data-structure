#include <stdio.h>
#define SIZE 5
int stack[SIZE], top = -1;
void push(int x) {
    if(top == SIZE-1)
        printf("Stack Overflow\n");
    else
        stack[++top] = x;
}

void pop() {
    if(top == -1)
        printf("Stack Underflow\n");
    else
        top--;
}

void display() {
    int i;
    for(i = top; i >= 0; i--)
        printf("%d ", stack[i]);
    printf("\n");
}

