void quickSort(int a[], int low, int high) {
    int i = low, j = high, pivot = a[(low+high)/2], temp;

    while(i <= j) {
        while(a[i] < pivot) i++;
        while(a[j] > pivot) j--;
        if(i <= j) {
            temp = a[i]; a[i] = a[j]; a[j] = temp;
            i++; j--;
        }
    }

    if(low < j) quickSort(a, low, j);
    if(i < high) quickSort(a, i, high);
}

