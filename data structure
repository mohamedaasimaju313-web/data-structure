    for(i = 0; i < rows; i++) {
        for(j = 0; j < cols; j++)
            printf("%d ", a[i][j]);
        printf("\n");
    }

    // Check sparse condition
    if(zeroCount > total / 2)
        printf("\nIt is a Sparse Matrix.\n");
    else
        printf("\nIt is NOT a Sparse Matrix.\n");

    return 0;
}








